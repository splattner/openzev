{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "simple",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        "frontend/package.json",
        {
          "type": "yaml",
          "path": "helm/openzev/Chart.yaml",
          "jsonpath": "$.version"
        },
        {
          "type": "yaml",
          "path": "helm/openzev/Chart.yaml",
          "jsonpath": "$.appVersion"
        }
      ]
    }
  }
}
