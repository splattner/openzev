# Copy this file to .env and adjust values
SECRET_KEY=change-me-in-production-use-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — pick one:
# SQLite (default, no extra setup)
DATABASE_URL=sqlite:///db.sqlite3
# PostgreSQL
# DATABASE_URL=postgres://openzev:openzev@db:5432/openzev
# MariaDB (requires libmariadb-dev + mysqlclient pip package)
# DATABASE_URL=mysql://openzev:openzev@db:3306/openzev

# CORS — frontend origin(s)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Media files storage path
MEDIA_ROOT=/app/media

# Email (use console backend for dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=openzev@example.com

# Frontend base URL (used in verification emails and OAuth callback redirects)
FRONTEND_URL=http://localhost:5173

# Celery (async tasks for email sending)
CELERY_BROKER_URL=redis://localhost:6379/0
